{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "branchPrefix": "renovate/",
  "baseBranches": [
    "rhoai-2.16",
    "rhoai-2.25",
    "rhoai-3.3",
    "rhoai-3.4",
    "rhoai-3.5-ea.1",
  ],
  "ignoreTests": true,
  "automergeType": "pr",
  "automerge": true,
  // Only use custom regex managers — no built-in language managers
  "enabledManagers": ["custom.regex"],
  // No rate limit on PRs
  "prHourlyLimit": 0,
  "packageRules": [
    {
      // Auto-merge digest-only updates for container images
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": true
    },
    {
      // Disable version bumps (major/minor/patch) — only digest updates are wanted
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      // Tracks container image references in additional-images-patch.yaml files,
      // matching the pattern: image:tag@sha256:digest
      "fileMatch": ["(^|/)additional-images-patch.yaml"],
      "customType": "regex",
      "datasourceTemplate": "docker",
      "matchStrings": [
        "(?<depName>[\\w\\.\\/\\-]+):(?<currentValue>[\\w\\.\\-]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "versioningTemplate": "docker"
    }
  ]
}
